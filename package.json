{
  "name": "esbuild-plugin-raw",
  "version": "0.4.0",
  "packageManager": "pnpm@10.15.0",
  "description": "esbuild plugin for raw import",
  "author": "hannoeru <me@hanlee.co>",
  "license": "MIT",
  "homepage": "https://github.com/hannoeru/esbuild-plugin-raw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hannoeru/esbuild-plugin-raw.git"
  },
  "bugs": "https://github.com/hannoeru/esbuild-plugin-raw/issues",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "index.d.ts",
  "files": [
    "client.d.ts",
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "dev": "npm run build -- --watch",
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "release": "npx git-ensure -a && npx bumpp --push --tag --commit",
    "example:serve": "npm -C example run serve",
    "example:build": "npm -C example run build",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "esbuild": "^0.14.36 || ^0.15.0 || ^0.16.0 || ^0.17.0 || ^0.18.0 || ^0.19.0 || ^0.20.0 || ^0.21.0 || ^0.22.0 || ^0.23.0 || ^0.24.0 || ^0.25.0 || ^0.26.0 || ^0.27.0 || ^0.28.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
